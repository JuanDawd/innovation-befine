{
  "name": "@befine/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env.local -- node --import tsx/esm src/migrate.ts",
    "db:push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env.local -- drizzle-kit studio",
    "db:check": "dotenv -e ../../.env.local -- drizzle-kit check",
    "db:seed": "dotenv -e ../../.env.local -- node --import tsx/esm src/seed.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/utils": "^0.4.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/ws": "^8.18.1",
    "drizzle-orm": "^0.44.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
