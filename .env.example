# ============================================================
# Innovation Befine — Environment Variables
# Copy to .env.local and fill in real values.
# ============================================================

# --- General ---
NODE_ENV=development
# Set to "1" to skip env validation (useful for CI build steps that don't need runtime vars)
SKIP_ENV_VALIDATION=

# --- Database (Neon Postgres) — T005 ---
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Auth (Better Auth) — T007 ---
# Minimum 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend) — T054 ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Real-time (Pusher) — T009 ---
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=us2

# --- Error tracking (Sentry) — T085 (optional for dev) ---
# SENTRY_DSN=https://xxxxx@o12345.ingest.sentry.io/12345
# SENTRY_AUTH_TOKEN=sntrys_xxxx

# --- Client-side public variables ---
NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=us2
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Development seed passwords (T011) ---
# SEED_ADMIN_PASSWORD=admin123
# SEED_SECRETARY_PASSWORD=secretary123
# SEED_STYLIST_PASSWORD=stylist123
# SEED_CLOTHIER_PASSWORD=clothier123
