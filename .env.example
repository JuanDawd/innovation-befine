# ============================================================
# Innovation Befine — Environment Variables
# Copy to .env.local and fill in real values.
# ============================================================

# --- General ---
NODE_ENV=development
# Set to "1" to skip env validation (useful for CI build steps that don't need runtime vars)
SKIP_ENV_VALIDATION=

# --- Database (Neon Postgres) — T005 ---
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Auth (Better Auth) — T007 ---
# Minimum 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend) — T054 ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Real-time (SSE) — T009 ---
# No environment variables needed — SSE uses native Next.js Route Handlers

# --- Error tracking (Sentry) — T085 (optional for dev) ---
# SENTRY_DSN=https://xxxxx@o12345.ingest.sentry.io/12345          # server-side
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o12345.ingest.sentry.io/12345  # client-side (same value)
# SENTRY_AUTH_TOKEN=sntrys_xxxx   # for source map uploads in CI
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# --- Client-side public variables ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Development seed passwords (T011) ---
# Override defaults used by `pnpm --filter @befine/db db:seed`
# Defaults: Admin123! / Secretary123! / Stylist123! / Clothier123!
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_SECRETARY_PASSWORD=Secretary123!
# SEED_STYLIST_PASSWORD=Stylist123!
# SEED_CLOTHIER_PASSWORD=Clothier123!
